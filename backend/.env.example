PORT=5000
# Use a hosted MongoDB connection string in production.
MONGODB_URI=mongodb://127.0.0.1:27017/new-optional-technology
JWT_SECRET=replace-with-a-very-strong-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
# Frontend site URL (recommended for hosted split frontend/backend deploys).
FRONTEND_URL=
# Optional comma-separated extra origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_COOKIE_NAME=new_option_session
AUTH_COOKIE_MAX_AGE_DAYS=7
REQUEST_BODY_LIMIT=200kb
TRUST_PROXY_HOPS=1
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@newoptiontechnology.com
ADMIN_PASSWORD=Admin@12345
ADMIN_PHONE=+250788790756
